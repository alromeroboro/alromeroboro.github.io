---
interface Props {
  label: string;
  color?: 'neon' | 'fuchsia' | 'amber' | 'accent';
  mb?: string;
}
const { label, color = 'neon', mb = 'mb-8' } = Astro.props;

const colorClasses: Record<string, string> = {
  neon:    'text-neon text-glow-neon',
  fuchsia: 'text-fuchsia text-glow-fuchsia',
  amber:   'text-amber text-glow-amber',
  accent:  'text-accent text-glow-accent',
};
const lineClasses: Record<string, string> = {
  neon:    'from-neon/40',
  fuchsia: 'from-fuchsia/40',
  amber:   'from-amber/40',
  accent:  'from-accent/40',
};
---
<div class={`flex items-center gap-4 ${mb}`}>
  <span class={`font-display text-lg sm:text-xl tracking-widest ${colorClasses[color]}`}>{label}</span>
  <div class={`flex-1 h-px bg-gradient-to-r ${lineClasses[color]} to-transparent`}></div>
</div>
