---
import { useTranslations } from '../../i18n';
import HomeSection from '../ui/HomeSection.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import BackToTop from '../ui/BackToTop.astro';

interface Props { locale: string; }
const { locale } = Astro.props;
const t = useTranslations(locale);
---
<HomeSection id="contact">
  <SectionHeading label={t('sections.contact')} color="neon" mb="mb-4" />
  <p class="text-xs text-muted/60 tracking-widest mb-10 text-center">{t('hero.cta')}</p>
  <div class="flex flex-col sm:flex-row gap-4 justify-center max-w-lg mx-auto">
    <a
      href="https://github.com/alromeroboro"
      target="_blank"
      rel="noopener noreferrer"
      class="flex-1 flex flex-col lg:flex-row items-center justify-center lg:justify-start gap-0 border border-neon/50 text-neon btn-charge btn-charge-neon"
      style="box-shadow: 0 0 8px #00ffff22;"
    >
      <div class="flex items-center justify-center px-3 py-2 shrink-0 lg:self-stretch">
        <svg class="w-10 h-10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </div>
      <div class="hidden lg:block w-px self-stretch bg-neon/20"></div>
      <div class="flex flex-col justify-center items-center lg:items-start gap-0.5 px-3 py-2">
        <span class="text-[10px] tracking-widest uppercase">CONNECT</span>
        <span class="hidden lg:block text-[9px] tracking-wider text-muted/60 uppercase">LINK: GITHUB</span>
        <span class="hidden lg:block text-[9px] tracking-wider text-neon/70 uppercase">STATUS: AVAILABLE</span>
      </div>
    </a>
    <a
      href="https://www.linkedin.com/in/alromeroboro/"
      target="_blank"
      rel="noopener noreferrer"
      class="flex-1 flex flex-col lg:flex-row items-center justify-center lg:justify-start gap-0 border border-fuchsia/50 text-fuchsia btn-charge btn-charge-fuchsia"
      style="box-shadow: 0 0 8px #ff00c822;"
    >
      <div class="flex items-center justify-center px-3 py-2 shrink-0 lg:self-stretch">
        <svg class="w-10 h-10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </div>
      <div class="hidden lg:block w-px self-stretch bg-fuchsia/20"></div>
      <div class="flex flex-col justify-center items-center lg:items-start gap-0.5 px-3 py-2">
        <span class="text-[10px] tracking-widest uppercase">SEND</span>
        <span class="hidden lg:block text-[9px] tracking-wider text-muted/60 uppercase">LINK: LINKEDIN</span>
        <span class="hidden lg:block text-[9px] tracking-wider text-fuchsia/70 uppercase">STATUS: AVAILABLE</span>
      </div>
    </a>
  </div>
  <BackToTop color="neon" />
</HomeSection>
