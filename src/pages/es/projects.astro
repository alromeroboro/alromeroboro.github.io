---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n';
import { getCollection } from 'astro:content';

const locale = Astro.currentLocale ?? 'es';
const t = useTranslations(locale);
const projects = await getCollection('projects', ({ id }) => id.startsWith('es/'));
const sorted = projects.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout locale={locale} title={`${t('nav.projects')} | Portfolio`} path="/projects">
  <section class="max-w-5xl mx-auto px-6 py-14 flex flex-col gap-8">

    <header class="relative">
      <div class="flex items-center gap-4">
        <div class="h-px flex-1 bg-gradient-to-r from-neon/50 to-transparent max-w-8"></div>
        <h1 class="font-display text-3xl font-black text-neon uppercase tracking-widest"
            style="text-shadow: 0 0 12px #00ffff, 0 0 40px #00ffff66;">
          // {t('nav.projects')}
        </h1>
        <div class="h-px flex-1 bg-gradient-to-l from-fuchsia/40 to-transparent"></div>
      </div>
      <p class="text-[10px] tracking-widest text-muted/40 mt-1 uppercase">CASOS DE ESTUDIO &gt;&gt; ACCESO CONCEDIDO</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {sorted.map((project, i) => (
        <article
          class="panel-holo border p-6 flex flex-col gap-3 relative"
          style={`background: rgba(0,8,16,0.88); border-color: ${i % 2 === 0 ? 'rgba(0,255,255,0.28)' : 'rgba(255,0,200,0.28)'};`}
        >
          <div class="absolute top-0 left-0 w-4 h-4 border-t-2 border-l-2"
               style={`border-color: ${i % 2 === 0 ? 'rgba(0,255,255,0.7)' : 'rgba(255,0,200,0.7)'};`}></div>
          <div class="absolute top-0 right-0 w-4 h-4 border-t-2 border-r-2"
               style={`border-color: ${i % 2 === 0 ? 'rgba(0,255,255,0.4)' : 'rgba(255,0,200,0.4)'};`}></div>
          <div class="absolute bottom-0 left-0 w-4 h-4 border-b-2 border-l-2"
               style={`border-color: ${i % 2 === 0 ? 'rgba(0,255,255,0.4)' : 'rgba(255,0,200,0.4)'};`}></div>
          <div class="absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2"
               style={`border-color: ${i % 2 === 0 ? 'rgba(0,255,255,0.7)' : 'rgba(255,0,200,0.7)'};`}></div>

          <h2
            class="font-display text-xs font-bold tracking-widest uppercase"
            style={`color: ${i % 2 === 0 ? '#00ffff' : '#ff00c8'}; text-shadow: 0 0 8px ${i % 2 === 0 ? '#00ffff88' : '#ff00c888'};`}
          >
            {project.data.title}
          </h2>
          <p class="text-xs text-muted/80 leading-relaxed">{project.data.description}</p>

          <div class="flex flex-wrap gap-2 mt-1">
            {project.data.stack.map((tag: string) => (
              <span
                class="px-2 py-0.5 text-[10px] tracking-widest"
                style="border: 1px solid rgba(0,255,255,0.2); color: rgba(192,200,208,0.6);"
              >
                {tag}
              </span>
            ))}
          </div>

          <div class="flex gap-4 mt-auto pt-3">
            {project.data.liveUrl && (
              <a
                href={project.data.liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-[10px] tracking-widest text-neon hover:underline uppercase"
              >
                DEMO EN VIVO &gt;&gt;
              </a>
            )}
            {project.data.repoUrl && (
              <a
                href={project.data.repoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="text-[10px] tracking-widest text-fuchsia hover:text-white transition-colors uppercase"
              >
                GITHUB &gt;&gt;
              </a>
            )}
          </div>
        </article>
      ))}
    </div>

    <a href="/es/" class="text-[10px] tracking-widest text-neon hover:underline uppercase">&lt;&lt; VOLVER_INICIO</a>
  </section>
</BaseLayout>
