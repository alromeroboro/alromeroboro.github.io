---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n';

const locale = Astro.currentLocale ?? 'en';
const t = useTranslations(locale);
---

<BaseLayout locale={locale} title={`${t('hero.name')} | Portfolio`} path="/">

  <!-- ── Hero / City backdrop ─────────────────────────────── -->
  <section class="relative flex flex-col items-center text-center px-5 py-2 gap-5 city-hero overflow-hidden">

    <!-- City skyline silhouette (window lights via ::after) -->
    <div class="city-skyline" aria-hidden="true"></div>

    <!-- Atmospheric neon fog layers -->
    <div class="fog-layer fog-cyan" aria-hidden="true"></div>
    <div class="fog-layer fog-fuchsia" aria-hidden="true"></div>
    <div class="fog-layer fog-amber" aria-hidden="true"></div>

    <!-- Bottom city glow + wet pavement reflection -->
    <div class="city-glow" aria-hidden="true"></div>

    <!-- Role tagline — fuchsia -->
    <div class="shadow-fuchsia p-3 w-full" style="background: rgba(10,0,14,0.85);" aria-hidden="true">
      <p
        class="relative z-10 font-display text-fuchsia text-sm tracking-widest text-glow-fuchsia uppercase"
      >
        {t('hero.role')}
      </p>
    </div>

    <!-- Welcome line with decorative rules -->
    <div class="relative z-10 flex items-center gap-4 w-full max-w-lg">
      <div class="flex-1 h-px bg-gradient-to-r from-transparent to-neon/50"></div>
      <span class="text-[10px] tracking-[0.3em] text-muted/70 whitespace-nowrap">
        {t('hero.welcome')}
      </span>
      <div class="flex-1 h-px bg-gradient-to-l from-transparent to-fuchsia/50"></div>
    </div>

    <!-- CTA button — accent red bordered (matches reference) -->
    <a
      href="#contact"
      class="relative z-10 cta-btn px-8 py-2.5 text-accent text-xs tracking-[0.2em] uppercase font-body overflow-hidden group"
      style="border: 1px solid #ff003c; box-shadow: 0 0 16px #ff003c55, inset 0 0 14px #ff003c11;"
    >
      <span class="relative z-10">{t('hero.cta')}</span>
      <div class="cta-fill absolute inset-0 bg-accent/10 translate-x-[-101%] group-hover:translate-x-0 transition-transform duration-300"></div>
    </a>
  </section>

  <!-- ── Info panels ──────────────────────────────────────── -->
  <section class="grid grid-cols-1 md:grid-cols-3 gap-4 px-6 pb-12">

    <!-- PROJECTS panel — cyan -->
    <div class="panel-holo border border-neon/30 p-6 flex flex-col gap-3 relative" style="background: rgba(0,10,18,0.85);">
      <!-- Corner brackets -->
      <div class="absolute top-0 left-0 w-4 h-4 border-t-2 border-l-2 border-neon/70"></div>
      <div class="absolute top-0 right-0 w-4 h-4 border-t-2 border-r-2 border-neon/40"></div>
      <div class="absolute bottom-0 left-0 w-4 h-4 border-b-2 border-l-2 border-neon/40"></div>
      <div class="absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2 border-neon/70"></div>

      <h2 class="font-display text-neon text-xs tracking-widest text-glow-neon">
        &#x25A0;&#x25A0; {t('panels.projects.title')}
      </h2>
      <div class="text-xs text-muted/70 space-y-1">
        <p>
          <span class="text-muted/40">LAST DEPLOY: </span>
          <span class="text-muted">NEXUS_01</span>
        </p>
        <p>
          <span class="text-muted/40">STACK: </span>
          <span class="text-muted">ASTRO / TS / CSS</span>
        </p>
      </div>
      <!-- Mini project thumbnail placeholder -->
      <div class="project-thumb w-full h-16 border border-neon/20 flex items-center justify-center overflow-hidden">
        <div class="thumb-inner w-full h-full"></div>
      </div>
      <a
        href="/projects"
        class="mt-1 px-4 py-1.5 border border-neon/60 text-neon text-[10px] tracking-widest uppercase text-center hover:bg-neon/10 transition-colors"
        style="box-shadow: 0 0 8px #00ffff22;"
      >
        {t('panels.projects.cta')}
      </a>
    </div>

    <!-- ABOUT ME panel — fuchsia -->
    <div class="panel-holo border border-fuchsia/30 p-6 flex flex-col gap-3 relative" style="background: rgba(10,0,14,0.85);">
      <div class="absolute top-0 left-0 w-4 h-4 border-t-2 border-l-2 border-fuchsia/70"></div>
      <div class="absolute top-0 right-0 w-4 h-4 border-t-2 border-r-2 border-fuchsia/40"></div>
      <div class="absolute bottom-0 left-0 w-4 h-4 border-b-2 border-l-2 border-fuchsia/40"></div>
      <div class="absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2 border-fuchsia/70"></div>

      <h2 class="font-display text-fuchsia text-xs tracking-widest text-glow-fuchsia">
        &#x25A0;&#x25A0; {t('panels.about.title')}
      </h2>
      <div class="text-xs text-muted/70 space-y-1">
        <p>
          <span class="text-muted/40">SKILLS: </span>
          <span class="text-muted">JAVASCRIPT / REACT</span>
        </p>
        <p>
          <span class="text-muted/40">EXPERIENCE: </span>
          <span class="text-muted">5+ YEARS</span>
        </p>
      </div>
      <div class="mt-auto h-px bg-gradient-to-r from-fuchsia/30 via-fuchsia/10 to-transparent"></div>
      <a href="/about" class="text-[10px] tracking-widest text-fuchsia hover:text-white transition-colors" style="text-shadow: 0 0 8px #ff00c866;">
        {t('nav.about')} &gt;&gt;
      </a>
    </div>

    <!-- CONTACT panel — mixed -->
    <div id="contact" class="panel-holo border border-neon/25 p-6 flex flex-col gap-3 relative" style="background: rgba(0,8,16,0.85);">
      <div class="absolute top-0 left-0 w-4 h-4 border-t-2 border-l-2 border-fuchsia/60"></div>
      <div class="absolute top-0 right-0 w-4 h-4 border-t-2 border-r-2 border-neon/60"></div>
      <div class="absolute bottom-0 left-0 w-4 h-4 border-b-2 border-l-2 border-neon/40"></div>
      <div class="absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2 border-fuchsia/40"></div>

      <h2 class="font-display text-neon text-xs tracking-widest text-glow-neon">
        &#x25A0;&#x25A0;&#x25A0; {t('panels.contact.title')}
      </h2>
      <div class="text-xs text-muted/70 space-y-1">
        <p>
          <span class="text-muted/40">LINKS: </span>
          <span class="text-muted">GITHUB / LINKEDIN</span>
        </p>
        <p>
          <span class="text-muted/40">STATUS: </span>
          <span class="text-neon">AVAILABLE</span>
        </p>
      </div>
      <div class="flex gap-3 mt-auto">
        <a
          href="https://github.com"
          target="_blank"
          rel="noopener noreferrer"
          class="flex-1 py-1.5 text-center border border-neon/50 text-neon text-[10px] tracking-widest uppercase hover:bg-neon/10 transition-colors"
          style="box-shadow: 0 0 8px #00ffff22;"
        >
          CONNECT
        </a>
        <a
          href="https://linkedin.com"
          target="_blank"
          rel="noopener noreferrer"
          class="flex-1 py-1.5 text-center border border-fuchsia/50 text-fuchsia text-[10px] tracking-widest uppercase hover:bg-fuchsia/10 transition-colors"
          style="box-shadow: 0 0 8px #ff00c822;"
        >
          SEND MESSAGE
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── City hero section ──────────────────────────────── */
  .city-hero {
    min-height: 400px;
    background:
      /* Top dark sky gradient */
      linear-gradient(to bottom, rgba(5,8,16,0.6) 0%, transparent 35%),
      /* Bottom ambient glow */
      linear-gradient(to top, rgba(0,255,255,0.06) 0%, transparent 55%);
  }

  /* Procedural building silhouettes */
  .city-skyline {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 220px;
    pointer-events: none;
    opacity: 0.72;
    background-image:
      repeating-linear-gradient(
        90deg,
        transparent 0px,
        transparent 10px,
        rgba(4, 12, 26, 0.95) 10px,
        rgba(4, 12, 26, 0.95) 22px,
        transparent 22px,
        transparent 26px,
        rgba(6, 10, 22, 0.90) 26px,
        rgba(6, 10, 22, 0.90) 44px,
        transparent 44px,
        transparent 50px,
        rgba(5, 12, 24, 0.95) 50px,
        rgba(5, 12, 24, 0.95) 60px,
        transparent 60px,
        transparent 68px,
        rgba(3, 10, 20, 0.95) 68px,
        rgba(3, 10, 20, 0.95) 86px,
        transparent 86px,
        transparent 94px,
        rgba(6, 14, 26, 0.90) 94px,
        rgba(6, 14, 26, 0.90) 108px
      );
    clip-path: polygon(
      0% 100%, 0% 60%, 2% 60%, 2% 20%, 5% 20%, 5% 40%, 8% 40%, 8% 10%,
      11% 10%, 11% 45%, 14% 45%, 14% 25%, 17% 25%, 17% 55%, 20% 55%, 20% 15%,
      23% 15%, 23% 50%, 26% 50%, 26% 30%, 29% 30%, 29% 5%, 32% 5%, 32% 35%,
      35% 35%, 35% 20%, 38% 20%, 38% 55%, 41% 55%, 41% 10%, 44% 10%, 44% 40%,
      47% 40%, 47% 22%, 50% 22%, 50% 50%, 53% 50%, 53% 8%, 56% 8%, 56% 38%,
      59% 38%, 59% 28%, 62% 28%, 62% 15%, 65% 15%, 65% 45%, 68% 45%, 68% 25%,
      71% 25%, 71% 55%, 74% 55%, 74% 12%, 77% 12%, 77% 42%, 80% 42%, 80% 30%,
      83% 30%, 83% 18%, 86% 18%, 86% 48%, 89% 48%, 89% 22%, 92% 22%, 92% 58%,
      95% 58%, 95% 35%, 98% 35%, 98% 60%, 100% 60%, 100% 100%
    );
  }

  /* Window lights scattered across buildings */
  .city-skyline::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    mix-blend-mode: screen;
    background-image:
      /* Building X 2-5%, min Y ~20% */
      radial-gradient(circle 2px   at  3%   30%, rgba(255,200,60,0.95) 0%, transparent 100%),
      radial-gradient(circle 1.5px at  3.5% 55%, rgba(255,240,200,0.85) 0%, transparent 100%),
      radial-gradient(circle 1px   at  4%   74%, rgba(0,255,255,0.75) 0%, transparent 100%),
      radial-gradient(circle 2px   at  2.5% 86%, rgba(255,180,40,0.80) 0%, transparent 100%),
      /* Building X 8-11%, min Y ~10% */
      radial-gradient(circle 1.5px at  9%   20%, rgba(255,200,60,0.95) 0%, transparent 100%),
      radial-gradient(circle 1px   at  9.5% 39%, rgba(255,240,200,0.80) 0%, transparent 100%),
      radial-gradient(circle 2px   at 10%   58%, rgba(255,0,200,0.65) 0%, transparent 100%),
      radial-gradient(circle 1.5px at  8.5% 72%, rgba(255,200,60,0.85) 0%, transparent 100%),
      radial-gradient(circle 1px   at  9%   87%, rgba(0,255,255,0.55) 0%, transparent 100%),
      /* Building X 14-17%, min Y ~25% */
      radial-gradient(circle 2px   at 15%   36%, rgba(255,200,60,0.90) 0%, transparent 100%),
      radial-gradient(circle 1.5px at 15.5% 57%, rgba(255,240,200,0.80) 0%, transparent 100%),
      radial-gradient(circle 1px   at 16%   76%, rgba(255,200,60,0.75) 0%, transparent 100%),
      /* Building X 20-23%, min Y ~15% */
      radial-gradient(circle 1px   at 21%   26%, rgba(0,255,255,0.75) 0%, transparent 100%),
      radial-gradient(circle 2px   at 21.5% 47%, rgba(255,200,60,0.95) 0%, transparent 100%),
      radial-gradient(circle 1.5px at 22%   67%, rgba(255,240,200,0.80) 0%, transparent 100%),
      radial-gradient(circle 2px   at 20.5% 83%, rgba(255,200,60,0.75) 0%, transparent 100%),
      /* Building X 26-29%, min Y ~30% */
      radial-gradient(circle 2px   at 27%   42%, rgba(255,200,60,0.95) 0%, transparent 100%),
      radial-gradient(circle 1.5px at 27.5% 63%, rgba(255,240,200,0.80) 0%, transparent 100%),
      radial-gradient(circle 1px   at 28%   80%, rgba(255,0,200,0.55) 0%, transparent 100%),
      /* Building X 29-32%, min Y ~5% (TALLEST) */
      radial-gradient(circle 1.5px at 30%   12%, rgba(0,255,255,0.65) 0%, transparent 100%),
      radial-gradient(circle 2px   at 30.5% 28%, rgba(255,200,60,0.95) 0%, transparent 100%),
      radial-gradient(circle 1px   at 31%   47%, rgba(255,240,200,0.80) 0%, transparent 100%),
      radial-gradient(circle 2px   at 30%   65%, rgba(255,200,60,0.85) 0%, transparent 100%),
      radial-gradient(circle 1.5px at 31%   83%, rgba(255,120,0,0.78) 0%, transparent 100%),
      /* Building X 35-38%, min Y ~20% */
      radial-gradient(circle 2px   at 36%   32%, rgba(255,200,60,0.90) 0%, transparent 100%),
      radial-gradient(circle 1.5px at 36.5% 56%, rgba(255,240,200,0.80) 0%, transparent 100%),
      radial-gradient(circle 1px   at 37%   75%, rgba(0,255,255,0.65) 0%, transparent 100%),
      /* Building X 41-44%, min Y ~10% */
      radial-gradient(circle 1.5px at 42%   20%, rgba(255,200,60,0.95) 0%, transparent 100%),
      radial-gradient(circle 2px   at 42.5% 44%, rgba(255,0,200,0.65) 0%, transparent 100%),
      radial-gradient(circle 1px   at 43%   66%, rgba(255,240,200,0.80) 0%, transparent 100%),
      radial-gradient(circle 2px   at 41.5% 84%, rgba(255,200,60,0.75) 0%, transparent 100%),
      /* Building X 47-50%, min Y ~22% */
      radial-gradient(circle 2px   at 48%   35%, rgba(255,200,60,0.95) 0%, transparent 100%),
      radial-gradient(circle 1.5px at 48.5% 57%, rgba(255,240,200,0.80) 0%, transparent 100%),
      radial-gradient(circle 1px   at 49%   78%, rgba(0,255,255,0.55) 0%, transparent 100%),
      /* Building X 53-56%, min Y ~8% (very tall) */
      radial-gradient(circle 1px   at 54%   16%, rgba(0,255,255,0.72) 0%, transparent 100%),
      radial-gradient(circle 2px   at 54.5% 36%, rgba(255,200,60,0.95) 0%, transparent 100%),
      radial-gradient(circle 1.5px at 55%   56%, rgba(255,240,200,0.80) 0%, transparent 100%),
      radial-gradient(circle 2px   at 54%   76%, rgba(255,120,0,0.75) 0%, transparent 100%),
      /* Building X 59-62%, min Y ~28% */
      radial-gradient(circle 2px   at 60%   40%, rgba(255,200,60,0.90) 0%, transparent 100%),
      radial-gradient(circle 1.5px at 60.5% 62%, rgba(255,0,200,0.55) 0%, transparent 100%),
      radial-gradient(circle 1px   at 61%   80%, rgba(255,240,200,0.80) 0%, transparent 100%),
      /* Building X 62-65%, min Y ~15% */
      radial-gradient(circle 1.5px at 63%   26%, rgba(255,200,60,0.95) 0%, transparent 100%),
      radial-gradient(circle 2px   at 63.5% 47%, rgba(0,255,255,0.65) 0%, transparent 100%),
      radial-gradient(circle 1px   at 64%   70%, rgba(255,240,200,0.80) 0%, transparent 100%),
      /* Building X 68-71%, min Y ~25% */
      radial-gradient(circle 2px   at 69%   38%, rgba(255,200,60,0.95) 0%, transparent 100%),
      radial-gradient(circle 1px   at 69.5% 60%, rgba(255,240,200,0.80) 0%, transparent 100%),
      radial-gradient(circle 2px   at 70%   78%, rgba(255,0,200,0.65) 0%, transparent 100%),
      /* Building X 74-77%, min Y ~12% */
      radial-gradient(circle 1px   at 75%   24%, rgba(0,255,255,0.72) 0%, transparent 100%),
      radial-gradient(circle 2px   at 75.5% 44%, rgba(255,200,60,0.95) 0%, transparent 100%),
      radial-gradient(circle 1.5px at 76%   65%, rgba(255,240,200,0.80) 0%, transparent 100%),
      radial-gradient(circle 2px   at 74.5% 84%, rgba(255,200,60,0.75) 0%, transparent 100%),
      /* Building X 83-86%, min Y ~18% */
      radial-gradient(circle 2px   at 84%   30%, rgba(255,200,60,0.90) 0%, transparent 100%),
      radial-gradient(circle 1.5px at 84.5% 52%, rgba(255,0,200,0.55) 0%, transparent 100%),
      radial-gradient(circle 1px   at 85%   72%, rgba(255,240,200,0.80) 0%, transparent 100%),
      /* Building X 89-92%, min Y ~22% */
      radial-gradient(circle 2px   at 90%   34%, rgba(255,200,60,0.90) 0%, transparent 100%),
      radial-gradient(circle 1.5px at 90.5% 57%, rgba(0,255,255,0.65) 0%, transparent 100%),
      radial-gradient(circle 1px   at 91%   78%, rgba(255,240,200,0.80) 0%, transparent 100%);
  }

  /* Atmospheric neon fog layers */
  .fog-layer {
    position: absolute;
    left: 0;
    right: 0;
    pointer-events: none;
  }
  .fog-cyan {
    bottom: 150px;
    height: 210px;
    background: radial-gradient(ellipse 65% 55% at 28% 72%, rgba(0,255,255,0.10) 0%, transparent 100%);
    filter: blur(28px);
    animation: haze-shimmer 14s ease-in-out infinite;
  }
  .fog-fuchsia {
    bottom: 110px;
    height: 190px;
    background: radial-gradient(ellipse 55% 50% at 72% 72%, rgba(255,0,200,0.09) 0%, transparent 100%);
    filter: blur(32px);
    animation: haze-shimmer 20s ease-in-out infinite reverse;
    animation-delay: 6s;
  }
  .fog-amber {
    bottom: 70px;
    height: 160px;
    background: radial-gradient(ellipse 45% 45% at 50% 78%, rgba(255,140,0,0.07) 0%, transparent 100%);
    filter: blur(38px);
    animation: haze-shimmer 17s ease-in-out infinite;
    animation-delay: 11s;
  }

  /* Neon glow reflection below skyline */
  .city-glow {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 130px;
    pointer-events: none;
    background: linear-gradient(
      to top,
      rgba(0, 255, 255, 0.14) 0%,
      rgba(255, 0, 200, 0.06) 35%,
      rgba(255, 140, 0, 0.04) 55%,
      transparent 100%
    );
    filter: blur(12px);
  }

  /* Project thumbnail mini scene */
  .project-thumb {
    background: rgba(0, 10, 20, 0.9);
  }
  .thumb-inner {
    background:
      linear-gradient(to top, rgba(0,255,255,0.15) 0%, transparent 60%),
      radial-gradient(ellipse at 30% 100%, rgba(255,0,200,0.1) 0%, transparent 50%),
      repeating-linear-gradient(
        90deg,
        transparent 0px, transparent 8px,
        rgba(0,255,255,0.04) 8px, rgba(0,255,255,0.04) 9px
      ),
      repeating-linear-gradient(
        0deg,
        transparent 0px, transparent 8px,
        rgba(0,255,255,0.03) 8px, rgba(0,255,255,0.03) 9px
      );
  }
</style>
