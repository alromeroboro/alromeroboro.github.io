---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n';
import ExperienceAccordion from '../components/ExperienceAccordion';

const locale = Astro.currentLocale ?? 'en';
const t = useTranslations(locale);

const jobs = [
  {
    name: 'Blinklearning',
    icon: '/images/bl.png',
    position: 'Senior Frontend Developer',
    date: '2022 – 2026',
    location: 'Madrid, Spain',
    description: 'Development of frontend applications using React, Storybook, and web accessibility standards.',
    skills: ['HTML', 'CSS', 'JavaScript', 'TypeScript', 'React', 'Redux', 'Storybook', 'W3C', 'Agile methodologies'],
  },
  {
    name: 'Vocces',
    icon: '/images/vo.png',
    position: 'Backend Developer',
    date: '2021 – 2022',
    location: 'Granada, Spain',
    description: 'Backend development using Laravel, applying hexagonal architecture and SOLID principles.',
    skills: ['PHP', 'Laravel', 'MySQL', 'REST APIs', 'Ports & Adapters', 'SOLID principles'],
  },
  {
    name: 'Local Concept',
    icon: '/images/lc.svg',
    position: 'Fullstack Developer',
    date: '2007 – 2021',
    location: 'Madrid, Spain',
    description: 'Development of web interfaces using JavaScript, HTML, and CSS integrated with backend systems.',
    projects: [
      { name: 'Translation Management System', skills: ['HTML', 'CSS', 'JavaScript', 'PHP', 'MySQL'] },
      { name: 'Glossary Management System', skills: ['HTML', 'CSS', 'JavaScript', 'Vue.js', 'MySQL'] },
      { name: 'ML Classification System', skills: ['HTML', 'CSS', 'JavaScript', 'React', 'Python', 'MySQL', 'Google Cloud AutoML', 'Google Cloud Storage'] },
    ],
  },
];

const skillIcons: Record<string, string> = {
  'HTML':         'html5',
  'CSS':          'css',
  'JavaScript':   'javascript',
  'TypeScript':   'typescript',
  'React':        'react',
  'Vue':          'vuedotjs',
  'Vue.js':       'vuedotjs',
  'Astro':        'astro',
  'Redux':        'redux',
  'Storybook':    'storybook',
  'PHP':          'php',
  'Laravel':      'laravel',
  'Python':       'python',
  'FastAPI':      'fastapi',
  'Django':       'django',
  'MySQL':        'mysql',
  'PostgreSQL':   'postgresql',
  'MongoDB':      'mongodb',
  'Claude Code':  'anthropic',
  'Codex':        'openaigym',
  'Git':          'git',
  'Jira':         'jira',
};
---

<BaseLayout locale={locale} title={`${t('hero.name')} | Portfolio`} path="/">

  <!-- ── Hero / City backdrop ─────────────────────────────── -->
  <section class="relative flex-1 flex flex-col items-center text-center py-2 gap-5 city-hero overflow-hidden">

    <!-- City skyline silhouette (window lights via ::after) -->
    <div class="city-skyline" aria-hidden="true"></div>

    <!-- Atmospheric neon fog layers -->
    <div class="fog-layer fog-cyan" aria-hidden="true"></div>
    <div class="fog-layer fog-fuchsia" aria-hidden="true"></div>
    <div class="fog-layer fog-amber" aria-hidden="true"></div>

    <!-- Bottom city glow + wet pavement reflection -->
    <div class="city-glow" aria-hidden="true"></div>

    <!-- Role tagline — fuchsia -->
    <div class="p-2 sm:p-3 self-stretch mx-2 sm:mx-4" style="background: rgba(10,0,14,0.85); box-shadow: 0 0 6px #ff00c833, 0 0 18px #ff00c81a;" aria-hidden="true">
      <p class="relative z-10 font-display text-fuchsia text-sm tracking-widest uppercase text-center w-full" style="text-shadow: 0 0 6px #ff00c888, 0 0 20px #ff00c844;">
        {t('hero.role')}
      </p>
      <div class="relative z-10 flex justify-center items-center gap-4 w-full mt-2">
        <div class="w-16 h-px bg-linear-to-r from-transparent to-neon/50"></div>
        <span class="text-[10px] tracking-[0.3em] text-neon/80 whitespace-nowrap">
          {t('hero.welcome')}
        </span>
        <div class="w-16 h-px bg-linear-to-l from-transparent to-fuchsia/50"></div>
      </div>
    </div>

    <!-- City banner -->
    <div class="relative z-10 w-full -mt-[10px] overflow-hidden city-banner h-[120px] sm:h-[200px]"
         style="background-image: url('/images/callao.png'); background-size: 100% auto; background-position: bottom; border-top: 1px solid rgba(0,255,255,0.35); border-bottom: 1px solid rgba(0,255,255,0.35); box-shadow: 0 -1px 8px rgba(0,255,255,0.15), 0 1px 8px rgba(0,255,255,0.15);">
      <!-- Noise grain overlay -->
      <div class="noise-grain absolute inset-0 pointer-events-none"></div>
    </div>

    <!-- Nav button bar -->
    <div class="relative z-10 mt-1 pb-2 hidden sm:flex items-center justify-center gap-6 sm:gap-10">

      <!-- About -->
      <a href="#about" class="nav-scroll-btn group inline-flex flex-col items-center gap-0.5 text-neon/60 hover:text-neon transition-colors duration-300">
        <span class="text-[9px] tracking-[0.35em] font-display uppercase">{t('nav.about')}</span>
        <span class="scroll-chevron text-base leading-none">▼</span>
      </a>

      <!-- Skills -->
      <a href="#skills" class="nav-scroll-btn group inline-flex flex-col items-center gap-0.5 text-amber/60 hover:text-amber transition-colors duration-300">
        <span class="text-[9px] tracking-[0.35em] font-display uppercase">{t('nav.skills')}</span>
        <span class="scroll-chevron text-base leading-none" style="animation-delay: 0.2s">▼</span>
      </a>

      <!-- Experience -->
      <a href="#experience" class="nav-scroll-btn group inline-flex flex-col items-center gap-0.5 text-accent/60 hover:text-accent transition-colors duration-300">
        <span class="text-[9px] tracking-[0.35em] font-display uppercase">{t('nav.experience')}</span>
        <span class="scroll-chevron text-base leading-none" style="animation-delay: 0.4s">▼</span>
      </a>

      <!-- Projects -->
      <a href="#projects" class="nav-scroll-btn group inline-flex flex-col items-center gap-0.5 text-fuchsia/60 hover:text-fuchsia transition-colors duration-300">
        <span class="text-[9px] tracking-[0.35em] font-display uppercase">{t('nav.projects')}</span>
        <span class="scroll-chevron text-base leading-none" style="animation-delay: 0.6s">▼</span>
      </a>

      <!-- Contact -->
      <a href="#contact" class="nav-scroll-btn group inline-flex flex-col items-center gap-0.5 text-neon/60 hover:text-neon transition-colors duration-300">
        <span class="text-[9px] tracking-[0.35em] font-display uppercase">{t('nav.contact')}</span>
        <span class="scroll-chevron text-base leading-none" style="animation-delay: 0.8s">▼</span>
      </a>

    </div>
  </section>

  <!-- ── About section ─────────────────────────────────── -->
  <section id="about" class="relative py-10 px-3 sm:px-6 section-cyan-haze">
    <div class="max-w-5xl mx-auto">

      <!-- Section heading -->
      <div class="flex items-center gap-4 mb-8">
        <span class="font-display text-neon text-lg sm:text-xl tracking-widest text-glow-neon">
          {t('sections.about')}
        </span>
        <div class="flex-1 h-px bg-gradient-to-r from-neon/40 to-transparent"></div>
      </div>

      <!-- HUD ID card -->
      <div class="relative border border-neon/30 grid grid-cols-1 md:grid-cols-[280px_1fr]"
           style="background: rgba(0,8,16,0.88); box-shadow: 0 0 24px rgba(0,255,255,0.08);">

        <!-- Corner brackets (outer panel) -->
        <div class="absolute top-0 left-0 w-5 h-5 border-t-2 border-l-2 border-neon/70"></div>
        <div class="absolute top-0 right-0 w-5 h-5 border-t-2 border-r-2 border-neon/40"></div>
        <div class="absolute bottom-0 left-0 w-5 h-5 border-b-2 border-l-2 border-neon/40"></div>
        <div class="absolute bottom-0 right-0 w-5 h-5 border-b-2 border-r-2 border-neon/70"></div>

        <!-- LEFT: Photo column -->
        <div class="relative flex flex-col border-b md:border-b-0 md:border-r border-neon/20 p-4 sm:p-6 items-center gap-3">
          <!-- ID label -->
          <div class="w-full flex items-center gap-2 mb-1">
            <span class="text-[9px] font-display tracking-[0.3em] text-neon/60 uppercase">
              &#x25A3;&#x25A3; {t('about.subject')}
            </span>
            <div class="flex-1 h-px bg-neon/20"></div>
          </div>

          <!-- Photo frame -->
          <div class="relative w-44 sm:w-52">
            <!-- Corner brackets around photo -->
            <div class="absolute -top-1 -left-1 w-4 h-4 border-t-2 border-l-2 border-neon/80 z-10"></div>
            <div class="absolute -top-1 -right-1 w-4 h-4 border-t-2 border-r-2 border-neon/50 z-10"></div>
            <div class="absolute -bottom-1 -left-1 w-4 h-4 border-b-2 border-l-2 border-neon/50 z-10"></div>
            <div class="absolute -bottom-1 -right-1 w-4 h-4 border-b-2 border-r-2 border-neon/80 z-10"></div>
            <img
              src="/images/selfie.png"
              alt="Alberto Romero"
              class="w-full h-auto block"
              style="filter: drop-shadow(0 0 8px rgba(0,255,255,0.35)) drop-shadow(0 0 20px rgba(0,255,255,0.15));"
            />
            <!-- Scan line overlay -->
            <div class="absolute inset-0 pointer-events-none"
                 style="background: repeating-linear-gradient(0deg, transparent 0px, transparent 3px, rgba(0,255,255,0.04) 3px, rgba(0,255,255,0.04) 4px);">
            </div>
          </div>

          <!-- Status badge -->
          <div class="w-full border border-neon/30 py-1 px-2 text-center mt-1"
               style="background: rgba(0,255,255,0.06);">
            <span class="text-[10px] font-display tracking-[0.25em] text-neon text-glow-neon uppercase">
              {t('about.status')}
            </span>
          </div>
        </div>

        <!-- RIGHT: Bio column -->
        <div class="p-6 sm:p-8 flex flex-col gap-5">
          <!-- Name + role -->
          <div>
            <div class="flex items-center gap-3">
              <p class="font-name text-neon text-xl sm:text-2xl tracking-widest text-glow-neon leading-tight">
                {t('hero.name')}
              </p>
              <img src="/images/logo.png" alt="AR" width="36" height="36" class="logo-mark" />
            </div>
            <p class="font-display text-fuchsia text-xs tracking-[0.3em] mt-1 uppercase"
               style="text-shadow: 0 0 8px rgba(255,0,200,0.5);">
              FRONTEND DEVELOPER
            </p>
            <div class="h-px bg-gradient-to-r from-neon/30 to-transparent mt-3"></div>
          </div>

          <!-- Bio paragraphs -->
          <p class="text-xs sm:text-sm text-muted/80 leading-relaxed tracking-wide">
            {t('about.bio1')}
          </p>
          <p class="text-xs sm:text-sm text-muted/80 leading-relaxed tracking-wide">
            {t('about.bio2')}
          </p>
          <p class="text-xs sm:text-sm text-muted/80 leading-relaxed tracking-wide">
            {t('about.bio3')}
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Skills section ───────────────────────────────── -->
  <section id="skills" class="relative py-10 px-3 sm:px-6 section-amber-haze">
    <div class="max-w-5xl mx-auto">
      <div class="flex items-center gap-4 mb-10">
        <span class="font-display text-amber text-lg sm:text-xl tracking-widest text-glow-amber">{t('sections.skills')}</span>
        <div class="flex-1 h-px bg-gradient-to-r from-amber/40 to-transparent"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">

        <!-- Frontend -->
        <div class="relative border border-amber/30 p-4" style="background: rgba(18,8,0,0.75);">
          <div class="absolute top-0 left-0 w-3 h-3 border-t border-l border-amber/60"></div>
          <div class="absolute bottom-0 right-0 w-3 h-3 border-b border-r border-amber/60"></div>
          <div class="flex items-center gap-2 mb-3">
            <span class="text-[9px] font-display tracking-[0.3em] text-amber/70 uppercase">▶ {t('skills.frontend')}</span>
            <div class="flex-1 h-px bg-amber/20"></div>
          </div>
          <div class="flex flex-wrap gap-1.5">
            {['HTML', 'CSS', 'JavaScript', 'TypeScript', 'React', 'Vue', 'Astro', 'Redux', 'Storybook', 'W3C'].map(s => {
              const slug = skillIcons[s];
              return (
                <span class="skill-tag">
                  {slug && <img src={`https://cdn.simpleicons.org/${slug}`} alt="" class="skill-icon" width="16" height="16" loading="lazy" />}
                  {s}
                </span>
              );
            })}
          </div>
        </div>

        <!-- Backend -->
        <div class="relative border border-amber/30 p-4" style="background: rgba(18,8,0,0.75);">
          <div class="absolute top-0 left-0 w-3 h-3 border-t border-l border-amber/60"></div>
          <div class="absolute bottom-0 right-0 w-3 h-3 border-b border-r border-amber/60"></div>
          <div class="flex items-center gap-2 mb-3">
            <span class="text-[9px] font-display tracking-[0.3em] text-amber/70 uppercase">▶ {t('skills.backend')}</span>
            <div class="flex-1 h-px bg-amber/20"></div>
          </div>
          <div class="flex flex-wrap gap-1.5">
            {['PHP', 'Laravel', 'Python', 'FastAPI', 'Django'].map(s => {
              const slug = skillIcons[s];
              return (
                <span class="skill-tag">
                  {slug && <img src={`https://cdn.simpleicons.org/${slug}`} alt="" class="skill-icon" width="16" height="16" loading="lazy" />}
                  {s}
                </span>
              );
            })}
          </div>
        </div>

        <!-- Databases -->
        <div class="relative border border-amber/30 p-4" style="background: rgba(18,8,0,0.75);">
          <div class="absolute top-0 left-0 w-3 h-3 border-t border-l border-amber/60"></div>
          <div class="absolute bottom-0 right-0 w-3 h-3 border-b border-r border-amber/60"></div>
          <div class="flex items-center gap-2 mb-3">
            <span class="text-[9px] font-display tracking-[0.3em] text-amber/70 uppercase">▶ {t('skills.databases')}</span>
            <div class="flex-1 h-px bg-amber/20"></div>
          </div>
          <div class="flex flex-wrap gap-1.5">
            {['MySQL', 'SQL', 'PostgreSQL', 'MongoDB'].map(s => {
              const slug = skillIcons[s];
              return (
                <span class="skill-tag">
                  {slug && <img src={`https://cdn.simpleicons.org/${slug}`} alt="" class="skill-icon" width="16" height="16" loading="lazy" />}
                  {s}
                </span>
              );
            })}
          </div>
        </div>

        <!-- AI Tools -->
        <div class="relative border border-amber/30 p-4" style="background: rgba(18,8,0,0.75);">
          <div class="absolute top-0 left-0 w-3 h-3 border-t border-l border-amber/60"></div>
          <div class="absolute bottom-0 right-0 w-3 h-3 border-b border-r border-amber/60"></div>
          <div class="flex items-center gap-2 mb-3">
            <span class="text-[9px] font-display tracking-[0.3em] text-amber/70 uppercase">▶ {t('skills.ai')}</span>
            <div class="flex-1 h-px bg-amber/20"></div>
          </div>
          <div class="flex flex-wrap gap-1.5">
            {['Claude Code', 'Codex'].map(s => {
              const slug = skillIcons[s];
              return (
                <span class="skill-tag">
                  {slug && <img src={`https://cdn.simpleicons.org/${slug}`} alt="" class="skill-icon" width="16" height="16" loading="lazy" />}
                  {s}
                </span>
              );
            })}
          </div>
        </div>

        <!-- Other Tools — full width -->
        <div class="relative border border-amber/30 p-4 sm:col-span-2" style="background: rgba(18,8,0,0.75);">
          <div class="absolute top-0 left-0 w-3 h-3 border-t border-l border-amber/60"></div>
          <div class="absolute bottom-0 right-0 w-3 h-3 border-b border-r border-amber/60"></div>
          <div class="flex items-center gap-2 mb-3">
            <span class="text-[9px] font-display tracking-[0.3em] text-amber/70 uppercase">▶ {t('skills.other')}</span>
            <div class="flex-1 h-px bg-amber/20"></div>
          </div>
          <div class="flex flex-wrap gap-1.5">
            {['Git', 'Jira', 'SOLID', 'Ports & Adapters', 'Agile methodologies'].map(s => {
              const slug = skillIcons[s];
              return (
                <span class="skill-tag">
                  {slug && <img src={`https://cdn.simpleicons.org/${slug}`} alt="" class="skill-icon" width="16" height="16" loading="lazy" />}
                  {s}
                </span>
              );
            })}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Experience section ────────────────────────────── -->
  <section id="experience" class="relative py-10 px-3 sm:px-6 section-accent-haze">
    <div class="max-w-5xl mx-auto">
      <div class="flex items-center gap-4 mb-10">
        <span class="font-display text-accent text-lg sm:text-xl tracking-widest text-glow-accent">{t('sections.experience')}</span>
        <div class="flex-1 h-px bg-gradient-to-r from-accent/40 to-transparent"></div>
      </div>
      <div class="relative">
        <div class="absolute top-0 left-0 w-4 h-4 border-t-2 border-l-2 border-accent/70 z-10"></div>
        <div class="absolute top-0 right-0 w-4 h-4 border-t-2 border-r-2 border-accent/40 z-10"></div>
        <div class="absolute bottom-0 left-0 w-4 h-4 border-b-2 border-l-2 border-accent/40 z-10"></div>
        <div class="absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2 border-accent/70 z-10"></div>
        <ExperienceAccordion client:load jobs={jobs} skillIcons={skillIcons} />
      </div>
    </div>
  </section>

  <!-- ── Projects section ──────────────────────────────── -->
  <section id="projects" class="relative py-10 px-3 sm:px-6 section-fuchsia-haze">
    <div class="max-w-5xl mx-auto">
      <div class="flex items-center gap-4 mb-10">
        <span class="font-display text-fuchsia text-lg sm:text-xl tracking-widest text-glow-fuchsia">{t('sections.projects')}</span>
        <div class="flex-1 h-px bg-gradient-to-r from-fuchsia/40 to-transparent"></div>
      </div>
      <div class="relative border border-fuchsia/50 p-6 sm:p-10 text-center mx-auto max-w-2xl" style="background: rgba(0,10,18,0.85); box-shadow: 0 0 18px rgba(255,0,200,0.12);">
        <div class="absolute top-0 left-0 w-4 h-4 border-t-2 border-l-2 border-fuchsia/70"></div>
        <div class="absolute top-0 right-0 w-4 h-4 border-t-2 border-r-2 border-fuchsia/40"></div>
        <div class="absolute bottom-0 left-0 w-4 h-4 border-b-2 border-l-2 border-fuchsia/40"></div>
        <div class="absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2 border-fuchsia/70"></div>
        <p class="font-display text-fuchsia text-sm tracking-widest text-glow-fuchsia">{t('sections.underConstruction')}</p>
        <p class="text-xs text-muted/60 mt-3 tracking-widest">{t('sections.wipText')}</p>
      </div>
    </div>
  </section>

  <!-- ── Contact section ───────────────────────────────── -->
  <section id="contact" class="relative py-10 px-3 sm:px-6">
    <div class="max-w-5xl mx-auto">
      <div class="flex items-center gap-4 mb-4">
        <span class="font-display text-neon text-lg sm:text-xl tracking-widest text-glow-neon">{t('sections.contact')}</span>
        <div class="flex-1 h-px bg-gradient-to-r from-neon/40 to-transparent"></div>
      </div>
      <p class="text-xs text-muted/60 tracking-widest mb-10 text-center">{t('hero.cta')}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center max-w-lg mx-auto">
        <a
          href="https://github.com/alromeroboro"
          target="_blank"
          rel="noopener noreferrer"
          class="flex-1 flex flex-col lg:flex-row items-center justify-center lg:justify-start gap-0 border border-neon/50 text-neon btn-charge btn-charge-neon"
          style="box-shadow: 0 0 8px #00ffff22;"
        >
          <div class="flex items-center justify-center px-3 py-2 shrink-0 lg:self-stretch">
            <svg class="w-10 h-10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </div>
          <div class="hidden lg:block w-px self-stretch bg-neon/20"></div>
          <div class="flex flex-col justify-center items-center lg:items-start gap-0.5 px-3 py-2">
            <span class="text-[10px] tracking-widest uppercase">CONNECT</span>
            <span class="hidden lg:block text-[9px] tracking-wider text-muted/60 uppercase">LINK: GITHUB</span>
            <span class="hidden lg:block text-[9px] tracking-wider text-neon/70 uppercase">STATUS: AVAILABLE</span>
          </div>
        </a>
        <a
          href="https://www.linkedin.com/in/alromeroboro/"
          target="_blank"
          rel="noopener noreferrer"
          class="flex-1 flex flex-col lg:flex-row items-center justify-center lg:justify-start gap-0 border border-fuchsia/50 text-fuchsia btn-charge btn-charge-fuchsia"
          style="box-shadow: 0 0 8px #ff00c822;"
        >
          <div class="flex items-center justify-center px-3 py-2 shrink-0 lg:self-stretch">
            <svg class="w-10 h-10" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
